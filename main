restrict_main_merge_source:
  stage: change_verification
  script:
    - |
      if [ "$CI_MERGE_REQUEST_TARGET_BRANCH_NAME" = "main" ] && \
         [ "$CI_MERGE_REQUEST_SOURCE_BRANCH_NAME" != "development" ]; then
        echo "Only development can be merged into main"
        exit 1
      fi
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
      when: always
